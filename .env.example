# ==============================================================================
# FashionVerse Backend — Environment Configuration Template (.env.example)
# Copy this file to '.env' and populate with your own credentials.
# ==============================================================================

# 1. Database Connection Settings (Required)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/fashionverse

# 2. JWT Session Security & Token Configurations (Required)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here_must_be_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_must_be_secure
JWT_ACCESS_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
JWT_ALGORITHM=HS256

# 3. AI & LLM Recommendations API Key (Required)
# Obtain from OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# 4. Azure Blob Storage Configuration (Optional)
# If left empty, the application automatically falls back to storing uploads on local disk.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=

# 5. SMTP Email Configuration (Optional - for User Registration Verification Codes)
# If SMTP_HOST is not provided, verification codes will print directly to the backend console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=FashionVerse <no-reply@fashionverse.com>
